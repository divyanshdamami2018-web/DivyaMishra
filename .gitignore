# ══════════════════════════════════════════════════════
#  .gitignore — Divya Mishra Counseling Platform
# ══════════════════════════════════════════════════════

# ── Environment Variables (NEVER commit these) ─────────
.env
.env.local
.env.*.local
.env.development
.env.production
backend/.env

# ── Node Dependencies ──────────────────────────────────
node_modules/
**/node_modules/

# ── Build Artifacts ────────────────────────────────────
dist/
dist-ssr/
build/

# ── Logs ───────────────────────────────────────────────
*.log
logs/
build.log
build.txt
build_v2.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / Editor Files ──────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*.suo

# ── Backend Utility / Debug Scripts ────────────────────
backend/check-admin-sid.js
backend/check-data.js
backend/check-sid.js
backend/fix-data.js
backend/get-keyword.js
backend/test-mongo.js
backend/test-razorpay.js
backend/test-twilio.js
backend/promote-admin.js

# ── lock files (keep package-lock.json for reproducibility)
# package-lock.json  ← intentionally NOT ignored
